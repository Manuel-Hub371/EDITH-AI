/* ============================================================
   NovaGen IDE - Enhanced Modern Dark Theme
   ============================================================ */

:root {
  /* NovaGen Enhanced Color Palette - Rich and Vibrant */
  --bg-darkest: #0d0e14;
  --bg-dark: #13141a;
  --bg-primary: #181924;
  --bg-secondary: #1d1e2b;
  --bg-tertiary: #242533;
  --bg-hover: #2a2b3d;
  --bg-active: #2f3145;

  --border-color: #2a2b3d;
  --border-subtle: #1d1e2b;
  --border-accent: #3d3e57;

  --text-primary: #e4e6f1;
  --text-secondary: #c0caf5;
  --text-muted: #6b7394;
  --text-dim: #4a4d6e;

  --accent-purple: #8b5cf6;
  --accent-purple-light: #a78bfa;
  --accent-purple-dark: #7c3aed;
  --accent-blue: #60a5fa;
  --accent-cyan: #22d3ee;
  --accent-green: #10b981;
  --accent-pink: #f472b6;
  --accent-orange: #fb923c;

  --gradient-primary: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 40%, #a78bfa 100%);
  --gradient-statusbar: linear-gradient(90deg, #6d28d9 0%, #7c3aed 50%, #8b5cf6 100%);
  --gradient-accent: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  --gradient-subtle: linear-gradient(180deg, rgba(139, 92, 246, 0.05) 0%, transparent 100%);

  --font-default: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif;
  --font-mono: 'Cascadia Code', 'JetBrains Mono', 'Fira Code', Consolas, monospace;

  --radius-sm: 3px;
  --radius-md: 5px;
  --radius-lg: 7px;

  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 8px rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 8px 16px rgba(0, 0, 0, 0.5);
  --shadow-purple: 0 0 20px rgba(139, 92, 246, 0.3);
}

/* Reset */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html,
body {
  height: 100%;
  font-family: var(--font-default);
  font-size: 12px;
  line-height: 1.4;
  overflow: hidden;
  background-color: var(--bg-darkest);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

#app {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--bg-active);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent-purple-dark);
}

::selection {
  background: rgba(139, 92, 246, 0.5);
  color: white;
}

/* Smooth animations */
* {
  transition: background-color 0.12s ease, border-color 0.12s ease, color 0.12s ease;
}

button,
input,
a {
  transition: all 0.12s ease;
}
a {
  transition: all 0.15s ease;
}

/* ============================================================
   Custom Title Bar
   ============================================================ */
.custom-titlebar {
  height: 35px;
  background: var(--bg-dark);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.titlebar-drag-region {
  flex: 1;
  display: flex;
  align-items: center;
  height: 100%;
  -webkit-app-region: drag;
  overflow: visible;
  max-width: calc(100% - 138px);
  /* Reserve space for 3 control buttons (46px each) */
}

.titlebar-left {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 12px;
  flex: 1;
  overflow: visible;
}

.titlebar-logo {
  display: flex;
  align-items: center;
  color: var(--accent-purple-light);
}

.titlebar-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.5px;
}

.titlebar-menu {
  display: flex;
  gap: 2px;
  margin-left: 8px;
  -webkit-app-region: no-drag;
  position: relative;
}

.menu-item-wrapper {
  position: relative;
}

.menu-item {
  padding: 6px 10px;
  font-size: 12px;
  color: var(--text-secondary);
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: all 0.15s;
  user-select: none;
}

.menu-item:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.menu-item.active {
  background: var(--bg-hover);
  color: var(--text-primary);
}

/* Dropdown Menu */
.dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  margin-top: 4px;
  min-width: 280px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(0, 0, 0, 0.1);
  padding: 4px;
  z-index: 1000;
  display: none;
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 0.15s, transform 0.15s;
}

.dropdown-menu.show {
  display: block;
  opacity: 1;
  transform: translateY(0);
}

.dropdown-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  color: var(--text-primary);
  font-size: 13px;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: all 0.15s;
  user-select: none;
}

.dropdown-item:hover {
  background: var(--bg-hover);
  color: var(--accent-purple-light);
}

.dropdown-item svg {
  flex-shrink: 0;
  color: var(--text-muted);
  transition: color 0.15s;
}

.dropdown-item:hover svg {
  color: var(--accent-purple-light);
}

.dropdown-item span:first-of-type {
  flex: 1;
}

.dropdown-item .shortcut {
  font-size: 11px;
  color: var(--text-dim);
  font-family: var(--font-mono);
  margin-left: auto;
}

.dropdown-separator {
  height: 1px;
  background: var(--border-subtle);
  margin: 4px 0;
}

.titlebar-center {
  flex: 1;
  display: flex;
  justify-content: center;
  -webkit-app-region: no-drag;
}

.titlebar-search {
  width: 100%;
  max-width: 500px;
  height: 24px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 10px;
  transition: all 0.2s;
}

.titlebar-search:focus-within {
  background: var(--bg-tertiary);
  border-color: var(--accent-purple-light);
  box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.1);
}

.titlebar-search svg {
  color: var(--text-muted);
  flex-shrink: 0;
}

.titlebar-search input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text-primary);
  font-size: 12px;
}

.titlebar-search input::placeholder {
  color: var(--text-muted);
}

.search-shortcut {
  font-size: 10px;
  color: var(--text-dim);
  padding: 2px 6px;
  background: var(--bg-dark);
  border-radius: 3px;
  font-family: var(--font-mono);
}

.titlebar-right {
  display: flex;
  gap: 4px;
  padding: 0 8px;
  -webkit-app-region: no-drag;
}

.titlebar-action-btn {
  height: 26px;
  padding: 0 10px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-size: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: all 0.15s;
}

.titlebar-action-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.titlebar-controls {
  display: flex;
  height: 100%;
  -webkit-app-region: no-drag;
  z-index: 10;
}

.titlebar-control-btn {
  width: 46px;
  height: 100%;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
  -webkit-app-region: no-drag;
}

.titlebar-control-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.titlebar-close:hover {
  background: #e81123;
  color: white;
}

/* ============================================================
   IDE Container
   ============================================================ */
.ide-container {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ============================================================
   Activity Bar
   ============================================================ */
.activity-bar {
  width: 48px;
  background: var(--bg-dark);
  border-right: 1px solid var(--border-color);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex-shrink: 0;
}

.activity-bar-top,
.activity-bar-bottom {
  display: flex;
  flex-direction: column;
  padding: 4px 0;
}

.activity-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--text-muted);
  position: relative;
  transition: all 0.2s;
}

.activity-icon:hover {
  color: var(--text-primary);
  background: var(--bg-hover);
}

.activity-icon.active {
  color: var(--accent-purple-light);
}

.activity-icon.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12px;
  bottom: 12px;
  width: 2px;
  background: var(--accent-purple-light);
  box-shadow: 0 0 10px var(--accent-purple-light);
}

/* ============================================================
   Sidebar
   ============================================================ */
.sidebar {
  width: 250px;
  background: var(--bg-primary);
  border-right: 1px solid var(--border-color);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.sidebar-header {
  height: 35px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border-subtle);
}

.sidebar-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
}

.sidebar-actions {
  display: flex;
  gap: 2px;
}

.sidebar-action {
  width: 22px;
  height: 22px;
  background: transparent;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  transition: all 0.15s;
}

.sidebar-action:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.sidebar-content {
  flex: 1;
  overflow-y: auto;
  padding: 16px 0;
}

/* No Folder State */
.no-folder-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  text-align: center;
}

.no-folder-icon {
  color: var(--text-dim);
  margin-bottom: 16px;
  opacity: 0.5;
}

.no-folder-text {
  color: var(--text-secondary);
  font-size: 13px;
  margin-bottom: 16px;
}

.open-folder-btn {
  padding: 8px 20px;
  background: var(--accent-purple);
  color: white;
  border: none;
  border-radius: var(--radius-md);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
}

.open-folder-btn:hover {
  background: var(--accent-purple-light);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(124, 58, 237, 0.5);
}

.open-folder-btn:active {
  transform: translateY(0);
}

/* ============================================================
   Main Content Area
   ============================================================ */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.editor-container {
  flex: 1;
  background: var(--bg-darkest);
  overflow: hidden;
  position: relative;
}

/* Welcome Screen */
.welcome-screen {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.welcome-logo {
  margin-bottom: 24px;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {

  0%,
  100% {
    transform: translateY(0px);
  }

  50% {
    transform: translateY(-10px);
  }
}

.welcome-title {
  font-size: 48px;
  font-weight: 700;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8px;
  letter-spacing: -0.5px;
}

.welcome-subtitle {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 48px;
}

.welcome-sections {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 48px;
  max-width: 800px;
}

.welcome-section h3 {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 0.5px;
  margin-bottom: 12px;
}

.welcome-link {
  display: block;
  padding: 8px 0;
  color: var(--accent-blue);
  text-decoration: none;
  font-size: 13px;
  transition: all 0.2s;
}

.welcome-link:hover {
  color: var(--accent-purple-light);
  padding-left: 8px;
}

.welcome-empty {
  color: var(--text-dim);
  font-size: 12px;
  font-style: italic;
}

/* Code Editor Container */
.code-editor-container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.editor-tabs {
  height: 35px;
  background: var(--bg-dark);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  padding: 0 8px;
  gap: 2px;
  overflow-x: auto;
}

.editor-tabs::-webkit-scrollbar {
  height: 0;
}

.tab {
  height: 28px;
  padding: 0 12px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  transition: all 0.15s;
  user-select: none;
  position: relative;
  flex-shrink: 0;
}

.tab:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.tab.active {
  background: var(--bg-darkest);
  color: var(--text-primary);
  border-bottom: 2px solid var(--accent-purple-light);
}

.tab-name {
  font-size: 13px;
  white-space: nowrap;
}

.tab-close {
  width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 3px;
  font-size: 18px;
  line-height: 1;
  color: var(--text-muted);
  transition: all 0.15s;
  margin-left: 4px;
}

.tab-close:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.tab.active .tab-close {
  color: var(--text-secondary);
}

.editor-wrapper {
  flex: 1;
  display: flex;
  overflow: auto;
}

.line-numbers {
  min-width: 50px;
  background: var(--bg-darkest);
  color: var(--text-dim);
  text-align: right;
  padding: 16px 12px;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 20px;
  user-select: none;
  border-right: 1px solid var(--border-subtle);
}

.code-editor {
  flex: 1;
  background: var(--bg-darkest);
  color: var(--text-primary);
  border: none;
  outline: none;
  resize: none;
  padding: 16px;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 20px;
  tab-size: 2;
}

/* ============================================================
   Bottom Panel
   ============================================================ */
.bottom-panel {
  height: 200px;
  background: var(--bg-dark);
  border-top: 1px solid var(--border-color);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.panel-header {
  height: 35px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
  border-bottom: 1px solid var(--border-subtle);
}

.panel-tabs {
  display: flex;
  gap: 2px;
}

.panel-tab {
  height: 35px;
  padding: 0 12px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-size: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
}

.panel-tab:hover {
  color: var(--text-primary);
}

.panel-tab.active {
  color: var(--text-primary);
  border-bottom-color: var(--accent-purple-light);
}

.panel-badge {
  padding: 1px 6px;
  background: var(--bg-tertiary);
  color: var(--text-muted);
  font-size: 10px;
  border-radius: 10px;
}

.panel-actions {
  display: flex;
  gap: 2px;
}

.panel-action-btn {
  width: 28px;
  height: 28px;
  background: transparent;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  transition: all 0.15s;
}

.panel-action-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.panel-content {
  flex: 1;
  overflow: auto;
  padding: 12px;
}

/* Terminal */
.terminal {
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 18px;
  color: var(--text-primary);
}

.terminal-line {
  margin-bottom: 4px;
}

.terminal-input-line {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}

.terminal-prompt {
  color: var(--accent-cyan);
  font-weight: 600;
}

.terminal-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 13px;
}

.terminal-input::placeholder {
  color: var(--text-dim);
}

/* ============================================================
   Status Bar
   ============================================================ */
.statusbar {
  height: 22px;
  background: var(--gradient-statusbar);
  box-shadow: 0 -1px 0 rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
  font-size: 12px;
  color: white;
  user-select: none;
}

.statusbar-left,
.statusbar-right {
  display: flex;
  gap: 12px;
}

.statusbar-item {
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  padding: 2px 6px;
  border-radius: 3px;
  transition: all 0.15s;
}

.statusbar-item:hover {
  background: rgba(255, 255, 255, 0.1);
}

.statusbar-item svg {
  width: 14px;
  height: 14px;
}