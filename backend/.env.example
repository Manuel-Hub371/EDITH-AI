# EDITH Backend Configuration
# Copy this file to .env and fill in your actual values.
# This file is safe to distribute — it contains no secrets.

# ── AI Provider ───────────────────────────────────────────
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string. Update with your credentials.
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/edith_db

# ── Google AI ─────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
